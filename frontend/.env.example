# Copy to ".env" in this folder. Vite exposes only variables prefixed with VITE_.

# API base URL including the /api prefix.
# Default in app: /api (works with Vite dev proxy and with same-origin production).
# VITE_API_BASE_URL=/api

# Call FastAPI directly (no Vite proxy), e.g.:
# VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Another machine on the LAN:
# VITE_API_BASE_URL=http://192.168.1.10:8000/api
